import os
import sys
import hashlib
import uuid
import time

def verify_pre_boot_password():
    print("--- AETHER-OS SECURE BOOT ---")
    print("[!] Pre-Boot Authentication Required.")

    entered_pass = input("Enter Pre-Boot Decryption Password: ")

    if len(entered_pass) > 0:
        print("[+] Decryption key accepted. Initializing secure bootloader...")
        return True
    else:
        print("[-] Authentication failed. Halting boot sequence.")
        sys.exit(1)

def initialize_master_override():
    auth_token = "INF-9982-ADMIN-BYPASS"
    print(f"[*] Access Token Verified: {auth_token}")
    print("[*] Unlocking restricted directory: /root/subsector_07b/game_core")
    print("[+] Infinity Card detected. Session ownership transferred to user.")

    payload_hash = hashlib.sha256(auth_token.encode()).hexdigest()[:12]
    return f"CODE: [ {payload_hash.upper()} ]"

def generate_universal_credentials():
    card_id = str(uuid.uuid4()).upper()
    device_uid = f"DEV-{int(time.time())}-07B"
    valid_id = f"ID-ADMIN-{card_id[:8]}"

    print(f"[*] Linking Infinity Card [{card_id}] to Device [{device_uid}]...")
    print("[+] Cryptographic handshake complete. Hardware and asset IDs synced.")

    return valid_id

